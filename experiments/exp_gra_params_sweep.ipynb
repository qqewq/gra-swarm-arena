# GRA params sweep

import numpy as np
import yaml
from pathlib import Path

from src.arena import Arena
from src.agents import Agent
from src.gra_core import GRACoordinator
from src.metrics import path_entropy


def run_episode_gra_params(entropy_weight, reset_threshold, seed=0):
    arena = Arena("config/arena_default.yaml")
    agents_cfg = yaml.safe_load(Path("config/agents_default.yaml").read_text(encoding="utf-8"))
    rng = np.random.RandomState(seed)

    agents = [
        Agent(
            start_pos=arena.start_positions[0],
            strategy="gra_guided",
            vision_radius=agents_cfg["vision_radius"],
            rng=rng,
        )
        for _ in range(agents_cfg["num_agents"])
    ]

    gra = GRACoordinator(entropy_weight=entropy_weight, reset_threshold=reset_threshold)
    gra_hint = gra.gra_hint_fn(arena)

    max_steps = agents_cfg["max_steps"]
    for _ in range(max_steps):
        for ag in agents:
            ag.step(arena, gra_hint)

    ents = [path_entropy(a.path) for a in agents]
    return float(np.mean(ents))


entropy_weights = [0.5, 1.0, 2.0]
reset_thresholds = [0.5, 0.7, 0.9]

results = []

for ew in entropy_weights:
    for rt in reset_thresholds:
        mean_ent = run_episode_gra_params(ew, rt)
        results.append((ew, rt, mean_ent))

results
import matplotlib.pyplot as plt

# build matrix for heatmap
ew_vals = sorted(set(r[0] for r in results))
rt_vals = sorted(set(r[1] for r in results))

matrix = np.zeros((len(ew_vals), len(rt_vals)))
for ew, rt, ent in results:
    i = ew_vals.index(ew)
    j = rt_vals.index(rt)
    matrix[i, j] = ent

fig, ax = plt.subplots(figsize=(5, 4))
im = ax.imshow(matrix, cmap="viridis", origin="lower")

ax.set_xticks(range(len(rt_vals)))
ax.set_yticks(range(len(ew_vals)))
ax.set_xticklabels(rt_vals)
ax.set_yticklabels(ew_vals)
ax.set_xlabel("reset_threshold")
ax.set_ylabel("entropy_weight")
ax.set_title("Mean entropy for GRA params")

plt.colorbar(im, ax=ax, label="mean entropy")
plt.tight_layout()
plt.show()
