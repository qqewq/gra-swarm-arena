# Entropy vs Trap Density

import numpy as np
import yaml
from pathlib import Path
from copy import deepcopy

from src.arena import Arena
from src.agents import Agent
from src.gra_core import GRACoordinator
from src.metrics import path_entropy

def run_one_episode(num_traps):
    # load base configs
    arena_cfg_path = Path("config/arena_default.yaml")
    arena_cfg = yaml.safe_load(arena_cfg_path.read_text(encoding="utf-8"))
    arena_cfg["num_traps"] = int(num_traps)

    # temporary arena instance from modified cfg (without saving)
    from tempfile import NamedTemporaryFile
    import os

    with NamedTemporaryFile(mode="w", suffix=".yaml", delete=False) as tmp:
        yaml.safe_dump(arena_cfg, tmp)
        tmp_path = tmp.name

    arena = Arena(tmp_path)
    os.remove(tmp_path)

    agents_cfg = yaml.safe_load(Path("config/agents_default.yaml").read_text(encoding="utf-8"))
    rng = np.random.RandomState(0)

    agents = []
    strategies = agents_cfg["strategies"]
    for i in range(agents_cfg["num_agents"]):
        strat = strategies[i % len(strategies)]
        agents.append(
            Agent(
                start_pos=arena.start_positions[0],
                strategy=strat,
                vision_radius=agents_cfg["vision_radius"],
                rng=rng,
            )
        )

    gra = GRACoordinator(**agents_cfg["gra_params"])
    gra_hint = gra.gra_hint_fn(arena)

    max_steps = agents_cfg["max_steps"]
    for _ in range(max_steps):
        for ag in agents:
            if ag.strategy == "gra_guided":
                ag.step(arena, gra_hint)
            else:
                ag.step(arena)

    ents = [path_entropy(a.path) for a in agents]
    return float(np.mean(ents))

trap_values = [0, 10, 20, 40, 60, 80]
mean_entropies = []

for t in trap_values:
    mean_entropies.append(run_one_episode(t))

import matplotlib.pyplot as plt

plt.plot(trap_values, mean_entropies, marker="o")
plt.xlabel("Number of traps")
plt.ylabel("Mean path entropy")
plt.title("Entropy vs trap density")
plt.grid(True)
plt.show()
