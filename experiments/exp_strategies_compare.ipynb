# Strategies comparison: random vs greedy vs GRA-guided

import numpy as np
import yaml
from pathlib import Path

from src.arena import Arena
from src.agents import Agent
from src.gra_core import GRACoordinator
from src.metrics import path_entropy

def run_episode_for_strategy(strategy_name, seed=0):
    arena = Arena("config/arena_default.yaml")
    agents_cfg = yaml.safe_load(Path("config/agents_default.yaml").read_text(encoding="utf-8"))
    rng = np.random.RandomState(seed)

    agents = [
        Agent(
            start_pos=arena.start_positions[0],
            strategy=strategy_name,
            vision_radius=agents_cfg["vision_radius"],
            rng=rng,
        )
        for _ in range(agents_cfg["num_agents"])
    ]

    gra = GRACoordinator(**agents_cfg["gra_params"])
    gra_hint = gra.gra_hint_fn(arena)

    max_steps = agents_cfg["max_steps"]
    steps_to_goal = []

    for step in range(max_steps):
        for ag in agents:
            prev_pos = ag.pos
            if ag.strategy == "gra_guided":
                ag.step(arena, gra_hint)
            else:
                ag.step(arena)
            if arena.is_goal(ag.pos) and not ag.reached_goal:
                ag.reached_goal = True
                steps_to_goal.append(step)

    ents = [path_entropy(a.path) for a in agents]
    return float(np.mean(ents)), steps_to_goal

strategies = ["random", "greedy", "gra_guided"]
results = {}

for s in strategies:
    ent, steps = run_episode_for_strategy(s)
    avg_steps = np.mean(steps) if steps else np.nan
    results[s] = {"mean_entropy": ent, "mean_steps": avg_steps}

results
import matplotlib.pyplot as plt

names = list(results.keys())
entropies = [results[s]["mean_entropy"] for s in names]
steps = [results[s]["mean_steps"] for s in names]

fig, ax = plt.subplots(1, 2, figsize=(10, 4))

ax[0].bar(names, entropies)
ax[0].set_title("Mean path entropy")
ax[0].set_ylabel("Entropy")

ax[1].bar(names, steps)
ax[1].set_title("Mean steps to goal")
ax[1].set_ylabel("Steps")

plt.tight_layout()
plt.show()
